{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aimoaas.com/standard/schemas/aimo-dictionary.schema.json",
  "title": "AIMO Dictionary",
  "type": "object",
  "additionalProperties": false,
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "description"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
